{
  "name": "@rtorcato/common-react",
  "version": "1.0.0",
  "type": "module",
  "author": "Richard Torcato",
  "description": "A React component package",
  "license": "ISC",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "homepage": "https://github.com/rtorcato/react-common#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rtorcato/react-common.git"
  },
  "bugs": {
    "url": "https://github.com/rtorcato/react-common/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.1.3",
  "keywords": [
    "react",
    "component",
    "typescript"
  ],
  "scripts": {
    "component-add": "npx shadcn@latest add",
    "build:css": "postcss src/styles/globals.css -o dist/styles.css",
    "build-dev": "rimraf ./dist && cross-env NODE_ENV=development node build.mjs && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "build-prod": "rimraf ./dist && cross-env NODE_ENV=production node build.mjs && tsc --emitDeclarationOnly --project tsconfig.build.json",
    "==================== Common ====================": "",
    "lint": "pnpm exec biome lint .",
    "format": "pnpm exec biome format .",
    "check:fix": "pnpm exec biome check --fix",
    "check": "pnpm exec biome check .",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm typecheck && pnpm check && pnpm exec vitest run",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "coverage": "vitest run --coverage",
    "knip": "knip",
    "================================================": ""
  },
  "files": [
    "CHANGELOG.md",
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/MyComponent": {
      "types": "./dist/components/MyComponent.d.ts",
      "import": "./dist/components/MyComponent.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "import": "./dist/hooks/index.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@rtorcato/js-tooling": "^2.18.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.9.3",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.20",
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.0",
    "esbuild-node-externals": "^1.23.1",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "knip": "^6.24.0",
    "lint-staged": "^17.0.8",
    "postcss": "8.5.16",
    "postcss-cli": "^11.0.0",
    "rimraf": "6.1.3",
    "semantic-release": "^25.0.3",
    "tailwindcss": "3.4.17",
    "typescript": "^6.0.3",
    "vite": "^6.0.7",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "next-themes": "^0.4.4",
    "tailwind-merge": "^2.6.0"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "@types/react-dom": {
      "optional": true
    }
  },
  "lint-staged": {
    "*.{js,ts,json,md}": [
      "pnpm exec biome lint",
      "pnpm exec biome format"
    ]
  },
  "publishConfig": {
    "access": "public"
  }
}
