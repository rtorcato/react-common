{
	"name": "@rtorcato/react-common",
	"version": "0.1.0",
	"type": "module",
	"author": "Richard Torcato",
	"description": "Common React foundation — headless hooks, the cn class-merge utility, and a theme provider.",
	"keywords": [
		"react",
		"hooks",
		"utils",
		"cn",
		"theme",
		"typescript"
	],
	"license": "ISC",
	"engines": {
		"node": ">=22.12"
	},
	"packageManager": "pnpm@11.1.3",
	"homepage": "https://github.com/rtorcato/react-common/tree/main/packages/react-common#readme",
	"repository": {
		"type": "git",
		"url": "https://github.com/rtorcato/react-common.git",
		"directory": "packages/react-common"
	},
	"bugs": {
		"url": "https://github.com/rtorcato/react-common/issues"
	},
	"sideEffects": false,
	"scripts": {
		"build-dev": "rimraf ./dist && cross-env NODE_ENV=development node build.mjs && tsc --emitDeclarationOnly --project tsconfig.build.json",
		"build-prod": "rimraf ./dist && cross-env NODE_ENV=production node build.mjs && tsc --emitDeclarationOnly --project tsconfig.build.json",
		"lint": "pnpm exec biome lint .",
		"format": "pnpm exec biome format .",
		"check:fix": "pnpm exec biome check --fix",
		"check": "pnpm exec biome check .",
		"typecheck": "tsc --noEmit",
		"doctor": "js-tooling doctor",
		"test": "vitest",
		"test:watch": "vitest --watch",
		"coverage": "vitest run --coverage"
	},
	"files": [
		"CHANGELOG.md",
		"dist"
	],
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"publishConfig": {
		"access": "public",
		"exports": {
			".": {
				"types": "./dist/index.d.ts",
				"import": "./dist/index.js"
			}
		}
	},
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@rtorcato/js-tooling": "^2.29.2",
		"@testing-library/jest-dom": "^6.6.3",
		"@testing-library/react": "^16.3.0",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.0.3",
		"@vitejs/plugin-react": "^5.0.4",
		"@vitest/coverage-v8": "^4.1.10",
		"cross-env": "^10.1.0",
		"esbuild": "^0.25.5",
		"esbuild-node-externals": "1.23.1",
		"jsdom": "^26.0.0",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"rimraf": "^6.0.1",
		"typescript": "^5.9.3",
		"vite": "^8.1.4",
		"vitest": "^4.1.10"
	},
	"dependencies": {
		"clsx": "^2.1.1",
		"next-themes": "^0.4.6",
		"tailwind-merge": "3.3.1"
	},
	"peerDependencies": {
		"react": "^19.2.7",
		"react-dom": "^19.2.7"
	},
	"peerDependenciesMeta": {
		"@types/react": {
			"optional": true
		},
		"@types/react-dom": {
			"optional": true
		}
	}
}
