{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // "target": "ES2017",
    // "module": "ESNext",
    "noEmit": false, // Emit output files
    "incremental": false, // Full rebuild each time; stale .tsbuildinfo otherwise skips .d.ts emit (rimraf only clears dist)
    "emitDeclarationOnly": true, // Emit JS and .d.ts files
    "declaration": true, // Generate .d.ts files
    "jsx": "react-jsx", // Use the new JSX transform
    "declarationMap": true, // (optional) Generate sourcemaps for d.ts files
    "outDir": "dist", // Output directory for build
    "paths": {
      "~/*": ["./src/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["build.mjs", "node_modules", "dist", "build", "coverage", "**/*.spec.ts", "**/*.test.ts", "release.config.ts", "OLD/examples", "OLD/ui-stories", "OLD", "test"]
}
